  "tabBar": {
    "color": "#667085",
    "selectedColor": "#0f766e",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/glucose/index",
        "text": "血糖"
      },
      {
        "pagePath": "pages/diet/index",
        "text": "饮食"
      },
      {
        "pagePath": "pages/reports/index",
        "text": "周报"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的"
      }
    ]
