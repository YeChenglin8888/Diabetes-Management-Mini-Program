{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^HealthMetricCard$": "@/components/HealthMetricCard.vue",
      "^WarmSectionHeader$": "@/components/WarmSectionHeader.vue",
      "^StatusPill$": "@/components/StatusPill.vue",
      "^EmptyState$": "@/components/EmptyState.vue",
      "^TrendChart$": "@/components/TrendChart.vue",
      "^FoodBasketItem$": "@/components/FoodBasketItem.vue",
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/auth/login",
      "style": {
        "navigationBarTitleText": "登录"
      }
    },
    {
      "path": "pages/home/index",
      "style": {
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/glucose/index",
      "style": {
        "navigationBarTitleText": "血糖记录"
      }
    },
    {
      "path": "pages/diet/index",
      "style": {
        "navigationBarTitleText": "饮食测算"
      }
    },
    {
      "path": "pages/recipes/index",
      "style": {
        "navigationBarTitleText": "降糖食谱"
      }
    },
    {
      "path": "pages/recipes/detail",
      "style": {
        "navigationBarTitleText": "食谱详情"
      }
    },
    {
      "path": "pages/reports/index",
      "style": {
        "navigationBarTitleText": "数据周报"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "个人中心"
      }
    }
